<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.cookshare.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action android:id="@+id/action_loginFragment_to_registerFragment" app:destination="@id/registerFragment" />
        <action android:id="@+id/action_loginFragment_to_feedFragment" app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.cookshare.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action android:id="@+id/action_registerFragment_to_feedFragment" app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment" app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.cookshare.ui.feed.FeedFragment"
        android:label="Feed"
        tools:layout="@layout/fragment_feed">
        <action android:id="@+id/action_feedFragment_to_recipeDetailFragment" app:destination="@id/recipeDetailFragment" />
        <action android:id="@+id/action_feedFragment_to_editRecipeFragment" app:destination="@id/editRecipeFragment" />
    </fragment>

    <fragment
        android:id="@+id/recipeDetailFragment"
        android:name="com.cookshare.ui.recipe.detail.RecipeDetailFragment"
        android:label="Recipe Detail"
        tools:layout="@layout/fragment_recipe_detail">
        <argument android:name="recipeId" app:argType="string" />
        <action android:id="@+id/action_recipeDetailFragment_to_editRecipeFragment" app:destination="@id/editRecipeFragment" />
    </fragment>

    <fragment
        android:id="@+id/editRecipeFragment"
        android:name="com.cookshare.ui.recipe.edit.EditRecipeFragment"
        android:label="Edit Recipe"
        tools:layout="@layout/fragment_edit_recipe">
        <argument android:name="recipeId" app:argType="string" app:nullable="true" android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/myRecipesFragment"
        android:name="com.cookshare.ui.recipe.myrecipes.MyRecipesFragment"
        android:label="My Recipes"
        tools:layout="@layout/fragment_my_recipes">
        <action android:id="@+id/action_myRecipesFragment_to_recipeDetailFragment" app:destination="@id/recipeDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.cookshare.ui.search.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search">
        <action android:id="@+id/action_searchFragment_to_recipeDetailFragment" app:destination="@id/recipeDetailFragment" />
        <action android:id="@+id/action_searchFragment_to_externalRecipeDetailFragment" app:destination="@id/externalRecipeDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/externalRecipeDetailFragment"
        android:name="com.cookshare.ui.search.ExternalRecipeDetailFragment"
        android:label="External Recipe"
        tools:layout="@layout/fragment_external_recipe_detail">
        <argument android:name="mealId" app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.cookshare.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action android:id="@+id/action_profileFragment_to_loginFragment" app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph" app:popUpToInclusive="true" />
    </fragment>

</navigation>